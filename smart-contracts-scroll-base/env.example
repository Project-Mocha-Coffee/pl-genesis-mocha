# Environment Configuration for Mocha Smart Contracts
# Copy this file to .env and fill in your values

# ==============================================
# DEPLOYMENT PRIVATE KEY
# ==============================================
# Your private key for contract deployment (without 0x prefix)
# ⚠️  SECURITY WARNING: Never commit your actual private key to version control
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ==============================================
# SCROLL NETWORK CONFIGURATION
# ==============================================

# Scroll Mainnet RPC URL (zkEVM Layer 2)
SCROLL_RPC_URL=https://rpc.scroll.io/

# Scroll Sepolia Testnet RPC URL
SCROLL_SEPOLIA_RPC_URL=https://sepolia-rpc.scroll.io/

# Alternative Scroll RPC (Ankr)
SCROLL_ANKR_RPC_URL=https://rpc.ankr.com/scroll

# ==============================================
# BASE NETWORK CONFIGURATION
# ==============================================

# Base Mainnet RPC URL
BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia Testnet RPC URL
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Alternative Base RPC endpoints (optional)
# BASE_ANKR_RPC_URL=https://rpc.ankr.com/base
# BASE_PUBLIC_NODE_RPC_URL=https://base-mainnet.public.blastapi.io

# ==============================================
# BLOCK EXPLORER API KEYS
# ==============================================

# Scroll block explorer API key (for contract verification)
# Get from: https://scrollscan.com/apis
SCROLL_API_KEY=your_scrollscan_api_key_here

# Base block explorer API key (for contract verification)
# Get from: https://basescan.org/apis
# Note: You can also use ETHERSCAN_API_KEY for Base networks
BASE_API_KEY=your_basescan_api_key_here

# Etherscan API key (works for Base networks too)
# Get from: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ==============================================
# ADDITIONAL RPC ENDPOINTS (OPTIONAL)
# ==============================================

# Ethereum Mainnet (if needed for testing)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_api_key_here

# Ethereum Sepolia Testnet (if needed for testing)
ETHEREUM_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here

# ==============================================
# DEPLOYMENT CONFIGURATION
# ==============================================

# Gas price settings (optional, auto-detected if not set)
# GAS_PRICE=20000000000  # 20 gwei
# GAS_LIMIT=8000000

# ==============================================
# EXAMPLE VALUES (DO NOT USE IN PRODUCTION)
# ==============================================
# PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# SCROLL_API_KEY=YourScrollScanApiKey123